{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 14,
  "skillListingBudgetFraction": 0.1,
  "env": {
    "ENABLE_TOOL_SEARCH": "1",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-sonnet-4-6",
    "BASH_DEFAULT_TIMEOUT_MS": "180000",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "MCP_SERVER_CONNECTION_BATCH_SIZE": "10",
    "MCP_TOOL_TIMEOUT": "60000"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit",
      "Write",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "Skill",
      "ExitPlanMode",
      "mcp__brave-search__*",
      "mcp__tavily-remote__*",
      "mcp__desktop-commander__*",
      "mcp__plugin_context7_context7__*",
      "mcp__plugin_playwright_playwright__*"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(sudo rm -rf *)",
      "Bash(git clean -fd*)",
      "Bash(chmod 777 *)",
      "Bash(npm publish*)",
      "Bash(pip install --user*)",
      "Edit(**/*credentials*)",
      "Edit(**/*password*)",
      "Edit(~/.zshrc)",
      "Edit(~/.zprofile)",
      "Edit(~/.bashrc)",
      "Edit(~/.bash_profile)",
      "Edit(.git/**)"
    ],
    "ask": [
      "Read(**/*credentials*)",
      "Read(**/*password*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/id_ecdsa*)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.kube/*)",
      "Bash(git rebase*)"
    ],
    "defaultMode": "plan"
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-context.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/link-skills.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/omc-companion-sync.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-gate.sh",
            "if": "Bash(git commit*)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-rm.sh",
            "if": "Bash(*rm *)"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prompt-rewriter.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/file-dispatcher.sh check",
            "timeout": 180
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/til-review.sh",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/vault-linker.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'exec \"$HOME/.local/share/mise/shims/node\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js\"'"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "claude-md-management@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "elastic-elasticsearch@elastic-agent-skills": true,
    "codex@openai-codex": true,
    "postman@claude-plugins-official": true,
    "temporal@temporal-marketplace": true,
    "slack@claude-plugins-official": true,
    "oh-my-claudecode@omc": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      },
      "autoUpdate": false
    },
    "elastic-agent-skills": {
      "source": {
        "source": "git",
        "url": "https://github.com/elastic/agent-skills.git"
      },
      "autoUpdate": false
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      },
      "autoUpdate": false
    },
    "temporal-marketplace": {
      "source": {
        "source": "github",
        "repo": "temporalio/claude-temporal-plugin"
      },
      "autoUpdate": false
    },
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      },
      "autoUpdate": false
    }
  },
  "language": "korean",
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "생각하는 중",
      "분석하는 중",
      "추론하는 중",
      "원인 파악 중",
      "코드 읽는 중",
      "파일 탐색 중",
      "구조 파악 중",
      "의존성 파악 중",
      "의존성 추적 중",
      "패턴 찾는 중",
      "로직 따라가는 중",
      "스펙 확인 중",
      "설계하는 중",
      "최적화 중",
      "리팩토링 중",
      "예외 처리 중",
      "쿼리 튜닝 중",
      "마이그레이션 중",
      "디버깅 중",
      "에러 재현 중",
      "로그 까보는 중",
      "스택트레이스 뜯는 중",
      "트러블슈팅 중",
      "엣지케이스 보는 중",
      "삽질하는 중",
      "코드 리뷰 중",
      "PR 까보는 중",
      "컨플릭트 해결 중",
      "빌드 돌리는 중",
      "CI 기다리는 중",
      "배포하는 중",
      "롤백하는 중",
      "핫픽스 중",
      "테스트 돌리는 중",
      "검증하는 중"
    ]
  },
  "spinnerTipsOverride": {
    "excludeDefault": false,
    "tips": [
      "Ctrl+W 단어 삭제 · Ctrl+U 줄 처음까지 삭제 · Ctrl+Y 되살리기",
      "Option+B/F로 단어 단위 커서 이동 (iTerm2: Option키를 Esc+로 설정)",
      "Ctrl+A 줄 맨 앞 · Ctrl+E 줄 맨 끝으로 커서 이동",
      "Ctrl+O로 대화 뷰어 토글 — 도구 호출 상세 및 사고 과정(회색 이탤릭) 확인",
      "Ctrl+B로 실행 중인 명령/에이전트를 백그라운드로 전환 (tmux 사용자는 두 번 입력)",
      "Ctrl+G로 $EDITOR에서 프롬프트 작성 가능 (긴 프롬프트에 유용)",
      "Option+Enter로 멀티라인 입력 · \\+Enter도 어디서든 동작",
      "Option+P 모델 전환 · Option+T 확장사고 토글 · Option+O 빠른 모드 토글",
      "Ctrl+V로 이미지/스크린샷 붙여넣기 (iTerm2는 Cmd+V도 가능, WSL은 Alt+V)",
      "! 접두사로 셸 명령 직접 실행 — ! npm test (출력이 컨텍스트에 추가됨)",
      "@파일경로로 파일을 대화에 참조 — @src/index.ts (경로 자동완성 지원)",
      "/btw로 대화 기록에 남지 않는 사이드 질문 (응답 중에도 사용 가능)",
      "/compact 뒤에 포커스 지시 가능 — /compact auth 변경사항에 집중",
      "/diff로 턴별 변경사항을 인터랙티브하게 확인 (좌우 화살표로 전환)",
      "/usage로 현재 세션 비용·토큰 사용량 확인 (/cost, /stats도 같은 명령의 별칭)",
      "/copy로 코드 블록 선택 복사 · w키로 파일에 직접 저장",
      "/context로 컨텍스트 윈도우 사용량 시각화 + 최적화 제안",
      "/branch로 현재 지점에서 대화를 분기할 수 있습니다",
      "/export로 대화 내용을 텍스트 파일로 내보내기",
      "/security-review로 현재 브랜치 변경사항의 보안 취약점 스캔",
      "/doctor로 설치 상태·설정 진단 — 문제 발견 시 f키로 자동 수정",
      "/config → Editor mode에서 vim 편집 모드 토글 (/vim 명령은 v2.1.92에서 제거됨)",
      "ultrathink을 프롬프트에 포함하면 해당 턴만 깊은 사고 모드 발동",
      "claude -p로 비대화형 실행 — cat error.log | claude -p '원인 분석'",
      "claude -n '이름'으로 세션에 이름 지정 → claude -r '이름'으로 재개",
      "claude --from-pr 123으로 PR에 연결된 세션을 바로 재개",
      "/resume 피커에서 Space(미리보기) · /(검색) · Ctrl+B(현재 브랜치 필터) · Ctrl+R(이름 변경)",
      ".worktreeinclude에 .env를 추가하면 worktree에 자동 복사",
      "/goal 조건으로 조건 달성까지 Claude가 자동으로 여러 턴 작업 — /goal clear로 중단",
      "/reload-skills로 세션 재시작 없이 새로 추가한 스킬 즉시 반영",
      "/simplify로 변경 코드 정리 리뷰 + 자동 적용 (버그 탐지 없는 cleanup 전용)",
      "Ctrl+R로 명령 히스토리 역방향 검색 · Ctrl+S로 검색 범위 전환 (세션 → 프로젝트 → 전체)",
      "Shift+Tab으로 권한 모드 순환 — default → acceptEdits → plan → auto"
    ]
  },
  "effortLevel": "high",
  "advisorModel": "opus",
  "showClearContextOnPlanAccept": true,
  "autoUpdatesChannel": "latest",
  "tui": "default",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "normal",
  "verbose": true,
  "preferredNotifChannel": "ghostty",
  "autoCompactEnabled": true,
  "teammateMode": "tmux",
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
