#:schema https://developers.openai.com/codex/config-schema.json
# Codex configuration (config.toml)
#
# Copy to ~/.codex/config.toml:
#   cp ~/.dotfiles/.codex/config.toml.example ~/.codex/config.toml
#
# Reference: https://developers.openai.com/codex/config-sample
# Notes
# - Root keys must appear before tables in TOML.
# - [projects] section is auto-managed by Codex (trust prompt on first use)
# - [notice] section is auto-managed by Codex

################################################################################
# Core Model Selection
################################################################################

model = "gpt-5.5"

# Communication style: none | friendly | pragmatic
personality = "pragmatic"

# Provider id selected from [model_providers]. Default: "openai".
model_provider = "openai"

# Optional model override for /review. Default: unset (uses current session model).
review_model = "gpt-5.5"

################################################################################
# Reasoning & Verbosity (Responses API capable models)
################################################################################

# Reasoning effort: minimal | low | medium | high | xhigh
model_reasoning_effort = "high"

# Optional override used when Codex runs in plan mode: none | minimal | low | medium | high | xhigh
plan_mode_reasoning_effort = "high"

# Reasoning summary: auto | concise | detailed | none
model_reasoning_summary = "auto"

# Text verbosity for GPT-5 family (Responses API): low | medium | high
model_verbosity = "medium"

################################################################################
# Approval & Sandbox
################################################################################

# When to ask for command approval:
# - untrusted: only known-safe read-only commands auto-run; others prompt
# - on-request: model decides when to ask (default)
# - never: never prompt (risky)
approval_policy = "on-request"

# Filesystem/network sandbox policy:
# - read-only (default)
# - workspace-write
# - danger-full-access (no sandbox; extremely risky)
sandbox_mode = "read-only"

################################################################################
# Project Documentation Controls
################################################################################

project_doc_max_bytes = 32768

################################################################################
# File Opener
################################################################################

# URI scheme: vscode | vscode-insiders | windsurf | cursor | none
file_opener = "vscode"

################################################################################
# Web Search
################################################################################

# Web search mode: disabled | cached | live. Default: "cached"
web_search = "cached"

# Suppress "Under-development features enabled" banner for opt-in unstable features (e.g. goals)
suppress_unstable_features_warning = true

################################################################################
# Context / Auto-Compaction
################################################################################

# Codex auto-compacts conversation history when context fills (built-in default
# is derived from the model context window). Override the trigger explicitly with
# a TOKEN COUNT (not a percentage — unlike Claude Code's 80% auto-compact).
# To emulate "compact at 80%": set this to (context_window * 0.8).
# Check the live window via statusLine "context-window-size", then multiply.
# 80% is a safety margin, not a quality-optimal point (Chroma "Context Rot" 2025
# shows quality degrades gradually well before the window fills).
# gpt-5.5 window = 272000 → 80% = 217600 (75% = 204000 is more conservative).
# model_auto_compact_token_limit = 217600

# Which part of the active context is charged against the limit above:
# - total            : count the full active context (default behavior)
# - body_after_prefix: count only tokens after the carried prefix in the current
#                       compaction window (avoids re-triggering too eagerly)
# model_auto_compact_token_limit_scope = "total"

# Customize the prompt used when compacting history (optional):
# compact_prompt = "..."
# experimental_compact_prompt_file = "/abs/path/to/compact-prompt.md"

################################################################################
# History
################################################################################

[history]
persistence = "save-all"
max_bytes = 5242880

################################################################################
# MCP Servers
################################################################################

[mcp_servers.context7]
command = "npx"
args = ["-y", "@upstash/context7-mcp"]

[mcp_servers.playwright]
command = "npx"
args = ["@playwright/mcp@latest"]

[mcp_servers.desktop-commander]
command = "npx"
args = ["-y", "@wonderwhy-er/desktop-commander"]

[mcp_servers.tavily-remote]
command = "sh"
args = ["-c", "if [ -f \"$HOME/.dotfiles/.env.local\" ]; then . \"$HOME/.dotfiles/.env.local\"; fi; exec npx -y mcp-remote \"https://mcp.tavily.com/mcp/?tavilyApiKey=$TAVILY_API_KEY\""]

[mcp_servers.brave-search]
command = "sh"
args = ["-c", "if [ -f \"$HOME/.dotfiles/.env.local\" ]; then . \"$HOME/.dotfiles/.env.local\"; fi; exec npx -y @brave/brave-search-mcp-server --transport stdio"]

################################################################################
# Feature Flags
################################################################################

[features]
multi_agent = true
# Keep v2 disabled on 0.138.0: spawn_agent is rejected by the API when this is enabled.
multi_agent_v2 = false
hooks = true
memories = true
# Persisted /goal workflows (Codex 0.128.0+)
# TUI commands: /goal create | /goal pause | /goal resume | /goal clear
goals = true

################################################################################
# UI
################################################################################

[tui]
notifications = false
animations = true
show_tooltips = true
