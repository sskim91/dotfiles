{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.dotfiles/.codex/hooks/session-context.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.dotfiles/.codex/hooks/link-skills.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.dotfiles/.codex/hooks/pre-commit-gate.sh\"",
            "statusMessage": "Running pre-commit security checks",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.dotfiles/.codex/hooks/block-rm.sh\"",
            "statusMessage": "Checking for unsafe rm commands",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.dotfiles/.codex/hooks/prompt-rewriter.sh\"",
            "statusMessage": "Preparing prompt rewrite context",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.dotfiles/.codex/hooks/file-dispatcher.sh\" check",
            "statusMessage": "Linting changed files",
            "timeout": 180
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.dotfiles/.codex/hooks/til-review.sh\"",
            "statusMessage": "Reviewing TIL notes",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.dotfiles/.codex/hooks/vault-linker.sh\"",
            "statusMessage": "Linking Obsidian vault",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
