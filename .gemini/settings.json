{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/refs/heads/main/schemas/settings.schema.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "name": "session-context",
            "type": "command",
            "command": "~/.gemini/hooks/session-context.sh",
            "description": "Inject current date/time context"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "write_file|replace|create_file",
        "hooks": [
          {
            "name": "check-secrets",
            "type": "command",
            "command": "~/.gemini/hooks/check-secrets.sh",
            "description": "Block hardcoded secrets in file writes",
            "timeout": 5000
          },
          {
            "name": "check-sensitive-files",
            "type": "command",
            "command": "~/.gemini/hooks/check-sensitive-files.sh",
            "description": "Block sensitive file types (.pem, .key, etc.)",
            "timeout": 5000
          },
          {
            "name": "check-env-files",
            "type": "command",
            "command": "~/.gemini/hooks/check-env-files.sh",
            "description": "Block .env and config files",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "folderTrust": {
      "enabled": true
    },
    "environmentVariableRedaction": {
      "enabled": true
    }
  },
  "mcpServers": {
    "context7": {
      "command": "bash",
      "args": [
        "-lc",
        "export PATH=\"$HOME/.local/share/mise/shims:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH\"; exec npx -y @upstash/context7-mcp@latest"
      ],
      "timeout": 30000
    },
    "playwright": {
      "command": "bash",
      "args": [
        "-lc",
        "export PATH=\"$HOME/.local/share/mise/shims:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH\"; exec npx -y @playwright/mcp@latest"
      ],
      "timeout": 30000
    },
    "desktop-commander": {
      "command": "bash",
      "args": [
        "-lc",
        "export PATH=\"$HOME/.local/share/mise/shims:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH\"; exec npx -y @wonderwhy-er/desktop-commander"
      ],
      "timeout": 30000
    },
    "tavily": {
      "command": "bash",
      "args": [
        "-lc",
        "if [ -f \"$HOME/.dotfiles/.env.local\" ]; then . \"$HOME/.dotfiles/.env.local\"; fi; export PATH=\"$HOME/.local/share/mise/shims:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH\"; exec npx -y mcp-remote \"https://mcp.tavily.com/mcp/?tavilyApiKey=${TAVILY_API_KEY}\""
      ],
      "timeout": 30000
    }
  },
  "tools": {
    "shell": {
      "showColor": true
    }
  },
  "general": {
    "enableNotifications": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d"
    }
  },
  "context": {
    "fileFiltering": {
      "respectGitIgnore": false
    }
  },
  "ui": {
    "theme": "Tokyo Night"
  },
  "model": {
    "name": "gemini-3-flash-preview"
  },
  "experimental": {
    "modelSteering": true,
    "autoMemory": true
  }
}
