# SSH Config Template
# Copy to ~/.ssh/config and replace with actual values.

# Oracle Cloud (example)
Host ocl
    HostName <YOUR_SERVER_IP>
    User <YOUR_USERNAME>
    IdentityFile ~/.ssh/<YOUR_KEY_FILE>

# Cluster of nodes sharing one User/key, differing only by IP (optional)
# Wildcard block holds the common settings; per-node blocks add only HostName.
# SSH merges all matching blocks (first value wins on conflict).
Host mycluster-*
    User <SHARED_USERNAME>
    IdentityFile ~/.ssh/<CLUSTER_KEY_FILE>
    IdentitiesOnly yes

Host mycluster-node1
    HostName <NODE1_IP>

Host mycluster-node2
    HostName <NODE2_IP>

# GitHub multi-account (optional)
# Personal account uses default github.com; company account uses an alias
# so a separate SSH key can be bound without `gh auth switch`.
# Clone company repos with: git@github.com-company:<org>/<repo>.git
Host github.com-company
    HostName github.com
    User git
    IdentityFile ~/.ssh/<COMPANY_KEY_FILE>
    IdentitiesOnly yes
    AddKeysToAgent yes
    UseKeychain yes
