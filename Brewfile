# =============================================================================
# Homebrew Formulae (Required CLI Tools)
#
# GUI applications live in Brewfile.cask so fresh bootstrap can continue even
# when a vendor cask is temporarily unavailable.
# =============================================================================

# --- Shell & Core ---
brew "bash"
brew "coreutils"
brew "gnu-tar"
brew "pkgconf"

# --- File & Navigation ---
brew "bat"
brew "duf"
brew "dust"
brew "eza"
brew "fd"
brew "fzf"
brew "sd"
brew "yazi"
brew "zoxide"

# --- System Monitoring ---
brew "htop"
brew "hyperfine"
brew "procs"

# --- Editor & Multiplexer ---
brew "neovim"
brew "tmux"

# --- Git Tooling ---
brew "gh"
brew "git-delta"
brew "lazygit"
brew "pre-commit"

# --- Code Search ---
brew "ast-grep"

# --- Language Servers ---
brew "jdtls"
brew "kotlin-language-server"
brew "lua-language-server"

# --- Runtime Management ---
brew "mise"

# --- Database ---
brew "mysql-client"

# --- Web / Networking ---
brew "doggo"
brew "httpd"
brew "httpie"

# --- Data Tools ---
brew "yq"

# --- Media ---
brew "poppler"
brew "yt-dlp"

# --- Docs & Help ---
brew "glow"
brew "tlrc"

# --- AI CLI ---
# Antigravity CLI is installed by install.sh with the official installer.
# Keep Gemini CLI available as a migration fallback until the cutoff.
brew "gemini-cli"
brew "llmfit"
brew "opencode"
